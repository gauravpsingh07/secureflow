// SecureFlow — SaaS Security Posture + Threat Detection Platform
// Docs: https://pris.ly/d/prisma-schema
//
// Tenant isolation is enforced in two layers:
//   1. Application: every query for a tenant-scoped model goes through
//      lib/db/tenant.ts, which injects `tenantId`.
//   2. Database: Postgres Row-Level Security policies (added via raw SQL in the
//      `*_rls` migration) enforce isolation when the request sets the
//      `app.current_tenant` session variable. See lib/db/rls.ts.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users          User[]
  invites        Invite[]
  apiKeys          ApiKey[]
  securityEvents   SecurityEvent[]
  alerts           Alert[]
  detectorSettings DetectorSetting[]
  approvalRequests ApprovalRequest[]
  notifications    Notification[]
  secretScans      SecretScan[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  tenantId     String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A pending invitation to join a tenant. An admin generates one; the recipient
// redeems the token to create their account with the assigned role.
model Invite {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       Role      @default(ANALYST)
  token      String    @unique
  invitedBy  String?
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

// Types of security telemetry the platform ingests and reasons about.
enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_RESET
  MFA_CHALLENGE
  API_REQUEST
  PERMISSION_CHANGE
}

// An ingestion credential. The raw key is shown once at creation; we persist
// only its SHA-256 hash. `prefix` is a non-secret display label (e.g. "sf_AbC1").
model ApiKey {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  hashedKey      String    @unique
  prefix         String
  rateLimitPerMin Int      @default(600)
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A normalized security/login event. `raw` keeps the original payload; the
// promoted columns power filtering and detection.
model SecurityEvent {
  id         String            @id @default(cuid())
  tenantId   String
  type       SecurityEventType
  actorEmail String?
  ip         String?
  country    String?
  city       String?
  latitude   Float?
  longitude  Float?
  userAgent  String?
  success    Boolean           @default(true)
  raw        Json?
  occurredAt DateTime          @default(now())
  createdAt  DateTime          @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([tenantId, occurredAt])
  @@index([tenantId, type])
  @@index([tenantId, actorEmail])
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

// Output of the detection engine. One row per correlated incident
// (`dedupeKey`); repeat firings update `lastSeen`, `score`, and `evidence`.
model Alert {
  id          String        @id @default(cuid())
  tenantId    String
  detectorKey String
  severity    AlertSeverity
  status      AlertStatus   @default(OPEN)
  title       String
  score       Float
  explanation String
  evidence    Json
  dedupeKey   String
  firstSeen   DateTime      @default(now())
  lastSeen    DateTime      @default(now())
  createdAt   DateTime      @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events AlertEvent[]

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status])
  @@index([tenantId, severity])
}

// Join table linking an alert to the security events that triggered it.
model AlertEvent {
  alertId         String
  securityEventId String

  alert Alert         @relation(fields: [alertId], references: [id], onDelete: Cascade)
  event SecurityEvent @relation(fields: [securityEventId], references: [id], onDelete: Cascade)

  @@id([alertId, securityEventId])
  @@index([securityEventId])
}

// Per-tenant tuning for a detector: on/off plus numeric threshold overrides.
model DetectorSetting {
  id          String   @id @default(cuid())
  tenantId    String
  detectorKey String
  enabled     Boolean  @default(true)
  config      Json?
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, detectorKey])
  @@index([tenantId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

// A risky action that requires an owner's sign-off before it executes.
model ApprovalRequest {
  id              String         @id @default(cuid())
  tenantId        String
  action          String
  note            String?
  status          ApprovalStatus @default(PENDING)
  requestedById   String
  requestedByName String
  decidedById     String?
  decidedByName   String?
  createdAt       DateTime       @default(now())
  decidedAt       DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// A workspace-level in-app notification (e.g. a new alert fired).
model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  alertId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, readAt])
}

// A secret-scan run over pasted or uploaded text.
model SecretScan {
  id           String   @id @default(cuid())
  tenantId     String
  source       String
  bytesScanned Int
  findingCount Int
  createdAt    DateTime @default(now())

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  findings SecretFinding[]

  @@index([tenantId, createdAt])
}

// One masked secret found in a scan. Accessed via its parent SecretScan.
model SecretFinding {
  id          String        @id @default(cuid())
  scanId      String
  ruleId      String
  ruleName    String
  severity    AlertSeverity
  line        Int
  column      Int
  maskedValue String
  remediation String

  scan SecretScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}
