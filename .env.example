# ---- Database (local Docker default) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/secureflow"

# ---- Auth: Auth.js (self-hosted, no external account) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# ---- Real-time: built-in SSE (no external service needed) ----

# ---- Detection worker: self-hosted Postgres-backed loop (no external service) ----
# Run the worker locally:  pnpm worker
WORKER_INTERVAL_MS="5000"
# How far back each detection pass looks, in minutes.
DETECTION_WINDOW_MINUTES="15"
# Optional shared secret protecting /api/jobs/run (and Vercel Cron). Unset = open in dev.
JOBS_RUN_SECRET=""

# ---- Demo ----
# When "true", write actions are blocked so the public demo stays read-only.
DEMO_MODE="false"
